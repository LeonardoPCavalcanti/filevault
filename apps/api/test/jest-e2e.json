{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": {
          "strict": false
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^@filevault/shared$": "<rootDir>/../../packages/shared/src"
  }
}
